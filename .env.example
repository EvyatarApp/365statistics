# Optional build-time config.
#
# This file documents the available env vars. Copy it to `.env.<mode>` and fill
# in real values ONLY for a private build where you want the token + group baked
# in (so no setup screen appears). Never commit a file with a real token.
#
# For the public/generic build (`npm run build`), leave these UNSET — the app
# will show a setup screen where each user enters their own group number + token.

# Your 365scores Bearer token (from DevTools → Network → Authorization header).
VITE_BOLAO_TOKEN=Bearer eyJ...

# The group number to display.
VITE_GROUP_ID=21495

# Optional display name for the group.
VITE_GROUP_NAME=My Group
