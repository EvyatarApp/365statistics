{
  "name": "bolao-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mitzpe": "vite --mode mitzpe",
    "dev:grasshoppers": "vite --mode grasshoppers",
    "build": "tsc -b && vite build",
    "build:mitzpe": "tsc -b && vite build --mode mitzpe --outDir dist-mitzpe",
    "build:grasshoppers": "tsc -b && vite build --mode grasshoppers --outDir dist-grasshoppers",
    "build:all": "npm run build:mitzpe && npm run build:grasshoppers",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
